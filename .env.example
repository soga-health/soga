# Payload CMS Secret
PAYLOAD_SECRET=your_32_character_payload_secret_here

# MongoDB Connection String
MONGODB_URI=mongodb://127.0.0.1:27017/soga-db

# AES-256-GCM Encryption Key (32-byte hex string)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Hedera HCS Configuration
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.123456
HEDERA_PRIVATE_KEY=302e020100300506032b657004220420...

# Twilio SMS Credentials
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Vercel Cron Secret (for securing /api/cron/reminders)
CRON_SECRET=your_cron_secret_token
